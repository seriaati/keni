<section class="cta" id="get-started">
  <div class="cta-inner reveal">
    <h2 class="cta-title">Start tracking<br /><em>with intention.</em></h2>
    <p class="cta-sub">Open source, self-hosted, and built to last. No subscriptions, no lock-in.</p>
    <div class="cta-actions">
      <a href="https://github.com" class="btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        View on GitHub
      </a>
      <a href="#features" class="btn-outline">Explore features</a>
    </div>
  </div>
</section>

<style>
.cta {
  padding: clamp(64px, 8vw, 100px) 0;
}

.cta-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 clamp(20px, 5vw, 48px);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 20px;
}

.cta-title {
  font-family: var(--font-display);
  font-size: clamp(36px, 5vw, 64px);
  font-weight: 400;
  line-height: 1.08;
  color: var(--ink);
}
.cta-title em { font-style: italic; color: var(--forest-light); }

.cta-sub {
  font-size: clamp(14px, 1.5vw, 16px);
  color: var(--ink-mid);
  line-height: 1.65;
  max-width: 420px;
}

.cta-actions {
  display: flex;
  gap: 12px;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 8px;
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--forest);
  color: var(--cream);
  font-size: 15px;
  font-weight: 500;
  padding: 13px 26px;
  border-radius: var(--radius);
  transition:
    opacity 0.15s,
    transform 0.2s cubic-bezier(0.25, 1, 0.5, 1),
    box-shadow 0.2s cubic-bezier(0.25, 1, 0.5, 1);
}
.btn-primary:hover {
  opacity: 0.88;
  transform: translateY(-2px);
  box-shadow: 0 8px 24px oklch(18% 0.01 80 / 0.2);
}
.btn-primary:active {
  transform: translateY(0) scale(0.97);
  opacity: 1;
  box-shadow: none;
  transition-duration: 0.08s;
}

.btn-outline {
  display: inline-flex;
  align-items: center;
  font-size: 15px;
  font-weight: 500;
  color: var(--ink);
  border: 1.5px solid var(--sand-dark);
  padding: 12px 24px;
  border-radius: var(--radius);
  transition:
    border-color 0.2s,
    background 0.2s,
    transform 0.2s cubic-bezier(0.25, 1, 0.5, 1);
}
.btn-outline:hover {
  border-color: var(--forest);
  background: var(--cream-dark);
  transform: translateY(-2px);
}
.btn-outline:active {
  transform: translateY(0) scale(0.97);
  transition-duration: 0.08s;
}
</style>
